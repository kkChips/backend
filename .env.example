# Backend API environment variables (copy to .env and fill in real values)

# GLM / DeepSeek API
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=deepseek-chat
GLM_BASE_URL=https://api.deepseek.com

# JWT authentication
JWT_SECRET=please_change_this_to_a_random_long_string_in_production
JWT_ALGORITHM=HS256

# Database (SQLite for dev, MySQL/PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data.db
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/ai_learning

# CORS allowed origin (frontend domain in production)
# CORS_ORIGIN=http://your-domain.com
